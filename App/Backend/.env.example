# =============================================================================
# .env.example — Food Store Backend
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file — it contains secrets.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/db_name
# SQLAlchemy echo: set to "true" to log all SQL statements (dev only)
SQL_ECHO=false

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-at-least-32-chars
# JWT token expiration (optional, defaults shown)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to FRONTEND_URL if unset.
CORS_ORIGINS=http://localhost:5173

# ── Frontend URL (used for MP back_urls redirects after payment) ──────────────
FRONTEND_URL=http://localhost:5173

# =============================================================================
# MercadoPago Integration
# =============================================================================
# Get your credentials from: https://www.mercadopago.com.ar/developers/panel
# TEST- prefix = sandbox | APP_USR- prefix = production
# =============================================================================

MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-0000000000
PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000

# ── Seller account info (from MP dashboard > Test Accounts) ───────────────────
NUMERO_APLICACION=0000000000000000
USER_ID=0000000000
TEST_USER=TESTUSER0000000000000000000
CONTRASENA=your-test-seller-password
CODIGO_VERIFICACION=000000

# ── Webhook secret (from MP dashboard > Webhooks) ─────────────────────────────
# Used to validate HMAC-SHA256 signatures on IPN notifications.
# Generate it from the MP panel after configuring the webhook URL.
MP_WEBHOOK_SECRET=your-webhook-secret-from-mp-dashboard

# ── Ngrok tunnel URL (for local webhook delivery) ─────────────────────────────
# Start ngrok: ngrok http 8000
# Copy the HTTPS URL ngrok gives you (e.g. https://xxxx.ngrok-free.dev)
# In production, replace with your real HTTPS domain.
NGROK_URL=https://your-tunnel.ngrok-free.dev

# =============================================================================
# Cloudinary Integration (Image Uploads)
# =============================================================================
# Get your credentials from: https://console.cloudinary.com/
# =============================================================================

CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
